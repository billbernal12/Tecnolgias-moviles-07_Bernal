///ProductoAdapter.kt

package com.example.catalogoproductos

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView

class ProductoAdapter(private val productos: List<Producto>) : RecyclerView.Adapter<ProductoAdapter.ProductoViewHolder>() {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ProductoViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_producto, parent, false)
        return ProductoViewHolder(view)
    }

    override fun onBindViewHolder(holder: ProductoViewHolder, position: Int) {
        val producto = productos[position]
        holder.txtNombre.text = producto.nombre
        holder.txtCantidad.text = "Cantidad: ${producto.cantidad}"
        holder.txtPrecio.text = "S/ ${producto.precio}"
    }

    override fun getItemCount(): Int = productos.size

    class ProductoViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        val txtNombre: TextView = itemView.findViewById(R.id.txtNombre)
        val txtCantidad: TextView = itemView.findViewById(R.id.txtCantidad)
        val txtPrecio: TextView = itemView.findViewById(R.id.txtPrecio)
    }
}


///MainActivity.kt

package com.example.catalogoproductos

import android.content.SharedPreferences
import android.os.Bundle
import androidx.appcompat.app.AppCompatActivity
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView

class MainActivity : AppCompatActivity() {

    private lateinit var recyclerView: RecyclerView
    private lateinit var prefs: SharedPreferences

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        recyclerView = findViewById(R.id.recyclerView)
        recyclerView.layoutManager = LinearLayoutManager(this)

        prefs = getSharedPreferences("com.example.catalogoproductos_preferences", MODE_PRIVATE)

        val productos = cargarProductos()

        val adapter = ProductoAdapter(productos)
        recyclerView.adapter = adapter
    }

    private fun cargarProductos(): List<Producto> {
        val productos = mutableListOf<Producto>()

        // Cargar los productos desde SharedPreferences
        val producto1 = Producto("Producto 1", 10, 5.99)
        val producto2 = Producto("Producto 2", 5, 8.50)
        val producto3 = Producto("Producto 3", 20, 3.75)

        productos.add(producto1)
        productos.add(producto2)
        productos.add(producto3)

        // Guardar en SharedPreferences (como ejemplo)
        val editor = prefs.edit()
        editor.putString("producto1", producto1.nombre)
        editor.putInt("cantidad1", producto1.cantidad)
        editor.putFloat("precio1", producto1.precio.toFloat())
        editor.apply()

        return productos
    }
}



