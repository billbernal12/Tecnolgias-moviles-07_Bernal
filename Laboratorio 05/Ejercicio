package com.example.catalogoproductos

data class Producto(
    val nombre: String,
    val cantidad: Int,
    val precio: Double
)


///strings.xml

<resources>
    <string name="app_name">CatalogoProductos</string>
    <string name="producto_cantidad">Cantidad: %1$d</string>
