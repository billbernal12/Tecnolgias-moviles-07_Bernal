        <PreferenceScreen
            android:key="secondPrefScreenPref"
            android:title="Segunda pantalla de preferencias"
            android:summary="Haz clic aquí para ir a la Segunda pantalla">

            <EditTextPreference
                android:key="secondEditTextPref"
                android:title="Edit Text (segunda pantalla)"
